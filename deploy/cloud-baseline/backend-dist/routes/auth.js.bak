/**
 * 认证路由
 * POST /api/auth/login  — 账号密码登录，返回 JWT token
 * GET  /api/auth/me     — 返回当前用户信息
 */
import { Router } from 'express';
import { createConnection } from 'node:net';
import jwt from 'jsonwebtoken';
const router = Router();
function getUsers() {
    try {
        const raw = process.env.USERS_CONFIG;
        if (!raw) {
            // 默认账号
            return [
                { username: 'admin', password: 'admin123', displayName: '管理员' },
                { username: 'user1', password: 'pass123', displayName: '用户1' },
            ];
        }
        return JSON.parse(raw);
    }
    catch {
        console.error('[auth] USERS_CONFIG 解析失败，使用默认账号');
        return [
            { username: 'admin', password: 'admin123', displayName: '管理员' },
        ];
    }
}
/**
 * POST /api/auth/login
 * Body: { username: string, password: string }
 * Response: { success: true, data: { token, user } }
 */
router.post('/login', (req, res) => {
    const { username, password } = req.body;
    if (!username || !password) {
        res.status(400).json({ success: false, error: '请提供用户名和密码' });
        return;
    }
    const users = getUsers();
    const user = users.find((u) => u.username === username && u.password === password);
    if (!user) {
        res.status(401).json({ success: false, error: '用户名或密码错误' });
        return;
    }
    const secret = process.env.JWT_SECRET || 'gobs-secret-change-in-production';
    const payload = { username: user.username, displayName: user.displayName };
    const token = jwt.sign(payload, secret, { expiresIn: '7d' });
    res.json({
        success: true,
        data: {
            token,
            user: payload,
        },
    });
});
/**
 * GET /api/auth/me
 * 需要 JWT 鉴权（中间件已在 index.ts 挂载）
 * Response: { success: true, data: { user } }
 */
router.get('/me', (req, res) => {
    if (!req.user) {
        res.status(401).json({ success: false, error: '未认证' });
        return;
    }
    res.json({ success: true, data: { user: req.user } });
});
/**
 * GET /api/auth/matrix-bridge-token
 * 为当前已登录用户签发短期 bridge token，供前端在 iframe 中换取 SJ 的 sj_auth cookie
 */
router.get('/matrix-bridge-token', (req, res) => {
    if (!req.user) {
        res.status(401).json({ success: false, error: '未认证' });
        return;
    }
    const secret = process.env.JWT_SECRET || 'gobs-secret-change-in-production';
    const bridgePayload = {
        typ: 'matrix_bridge',
        email: `${req.user.username}@gobs.local`,
        isa: false,
        mf: [],
        cv: 1,
    };
    const bridgeToken = jwt.sign(bridgePayload, secret, { expiresIn: '5m' });
    res.json({ success: true, data: { token: bridgeToken } });
});

/**
 * GET /api/auth/matrix-tcp-probe?host=&port=
 * 探测 TikTok 矩阵目标地址是否可连接，避免 iframe 空白。
 */
router.get('/matrix-tcp-probe', async (req, res) => {
    if (!req.user) {
        res.status(401).json({ success: false, error: '未认证' });
        return;
    }
    try {
        const rawHost = String(req.query.host ?? '127.0.0.1').trim().toLowerCase();
        const targetPort = Math.min(65535, Math.max(1, parseInt(String(req.query.port ?? '3000'), 10) || 3000));
        const allowLocal = rawHost === 'localhost' ||
            rawHost === '127.0.0.1' ||
            rawHost === '::1' ||
            /^(10\.|192\.168\.|172\.(1[6-9]|2[0-9]|3[0-1])\.)\d{1,3}\.\d{1,3}$/.test(rawHost);
        if (!allowLocal) {
            res.json({ ok: true, skipped: true, host: rawHost, port: targetPort });
            return;
        }
        const connectHost = rawHost === 'localhost' ? '127.0.0.1' : (rawHost === '::1' ? '::1' : rawHost);
        const ok = await new Promise((resolve) => {
            const socket = createConnection({ port: targetPort, host: connectHost }, () => {
                socket.end();
                resolve(true);
            });
            socket.setTimeout(2000);
            socket.on('timeout', () => { socket.destroy(); resolve(false); });
            socket.on('error', () => { socket.destroy(); resolve(false); });
        });
        res.json({ ok, skipped: false, host: rawHost, port: targetPort });
    }
    catch (e) {
        res.status(500).json({ success: false, error: e instanceof Error ? e.message : 'probe failed' });
    }
});

export default router;
