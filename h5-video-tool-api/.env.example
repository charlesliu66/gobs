# ============================================================
# QAS H5 Video Tool API — 环境变量配置模板
# 使用方法：复制为 .env，填写必填项后启动
#
# 必填项（缺少任一服务将无法启动）：
#   COMPASS_API_URL, COMPASS_API_KEY
# 强烈建议修改（有默认值但不安全）：
#   JWT_SECRET, USERS_CONFIG
# 本地开发专用（不要上传到服务器）：
#   SERVER_HOST, SERVER_PASSWORD, DREAMINA_BIN, PYTHON_EXE
# ============================================================

# ========== 账号体系 & JWT 鉴权 ==========
# JWT 签名密钥，生产环境务必修改为强随机字符串
JWT_SECRET=gobs-secret-change-in-production
# 预设账号列表（JSON 数组），格式：[{"username":"xxx","password":"xxx","displayName":"xxx"}]
USERS_CONFIG=[{"username":"admin","password":"admin123","displayName":"管理员"},{"username":"user1","password":"pass123","displayName":"用户1"}]

# LLM（一键 Prompt / 文案）：优先 COMPASS_API_KEY（Gemini chat）；KEY2 多为 Veo 专用可无文本权限
# 可选文本模型（默认 gemini-2.5-flash）：COMPASS_GEMINI_MODEL=gemini-2.5-flash

# 代理（可选，访问 Compass 内网或防火墙时与 GEELARK_HTTP_PROXY 可同机）
# GEMINI_PROXY=http://127.0.0.1:7890
# 或使用系统代理：HTTPS_PROXY=http://127.0.0.1:7890

# Seedance (laozhang.ai 等)
SEEDANCE_API_URL=https://api.laozhang.ai/v2/generate/text
SEEDANCE_API_KEY=xxx

# Google OAuth (后端代理 Drive 时用)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# GeeLark (Phase 2)
GEELARK_API_KEY=xxx

# GeeLark TikTok 矩阵（批量评论、云手机、任务日志）- 与 SJ 项目一致，默认国际区 geelark.com
# 认证二选一：Bearer Token 或 Key 验证。若 Bearer 报 signature verification failure，可改用 Key 验证
# 方式 1：Bearer Token 认证（推荐，与 SJ 相同）
GEELARK_BEARER_TOKEN=你的Bearer_Token
# 方式 2：Key 验证（需同时配置 appId 和 apiKey）
# GEELARK_APP_ID=你的应用ID
# GEELARK_API_KEY=你的API_Key
# 国内区（geelark.cn）需显式指定：
# GEELARK_SJ_BASE_URL=https://openapi.geelark.cn/open/v1
# 一键发布报 connect ETIMEDOUT 时：与 Clash 同端口，例 http://127.0.0.1:7890；或与公司 HTTP 代理一致
# GEELARK_HTTP_PROXY=http://127.0.0.1:7890
# 视频上传到 OSS 时若遇 403，可设置代理（内网/防火墙环境）
# GEELARK_UPLOAD_PROXY=http://127.0.0.1:7890

# Compass 视频生成 + 文本 LLM（一键 Prompt 等，OpenAI 兼容 chat/completions）
COMPASS_API_URL=http://compass.llm.shopee.io/compass-api/v1
COMPASS_API_KEY=你的Compass_API_Key
# 推荐：LLM + 分镜图与 VEO3 共用第二把 Key（一键 Prompt / Imagen 优先用此 Key）
COMPASS_API_KEY2=你的Compass_API_Key2
# 可选：Gemini 文本模型（默认 gemini-2.5-flash；3.x 需项目白名单）
# COMPASS_GEMINI_MODEL=gemini-2.5-flash
# 仅在组织已开通对应模型时，用 VEO_MODELS 把 VEO3 加进 H5 下拉，例如：
# VEO_MODELS=veo-2.0-generate-001,veo-3.1-generate-001
# 图像生成：默认先 gemini-3.1-flash-image-preview（速），失败再 gemini-3-pro-image-preview（质）
# COMPASS_IMAGEN_MODEL=gemini-3.1-flash-image-preview
# 图像生成重试次数（建议 1~2；太高会把一次等待拉到几分钟）
# IMAGEN_RETRY_ATTEMPTS=2
# 单次图像请求超时毫秒（后端超时会快速失败，避免卡死）
# IMAGEN_REQUEST_TIMEOUT_MS=70000
# 排查「出图与输入框不符」时：COMPASS_IMAGEN_DEBUG=1（服务端日志打印实际 prompt 预览）
# 模型：veo-2 | veo-3（Google VEO）或 sora-2（OpenAI Sora），默认 veo-2
COMPASS_VIDEO_MODEL=veo-2
# Lyria 文生器乐（英文 prompt，约 32.8s/段）：POST /api/editor/music/generate
# COMPASS_LYRIA_MODEL=lyria-002

# ---------- Suno API（音乐生成，主引擎；Lyria 为 backup）----------
# 填入后 /api/editor/music/generate 优先调用 Suno，额度耗尽或报错时自动 fallback 到 Lyria
# API Key 获取：https://sunoapi.org/api-key
# SUNO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 可选：模型版本（默认 V4_5ALL）。可选值：V4 | V4_5 | V4_5PLUS | V4_5ALL | V5 | V5_5
# SUNO_MODEL=V4_5ALL
# 可选：自定义 API 网关（默认 https://api.sunoapi.org）
# SUNO_API_BASE_URL=https://api.sunoapi.org
# 前端可选模型（逗号分隔），默认仅 veo-2.0；若组织已开通 veo-3 可添加：veo-3.1-generate-001 等
# VEO_MODELS=veo-2.0-generate-001,veo-2.0-generate-exp

# ---------- 即梦 Dreamina CLI（H5 视频生成可选）----------
# 本机需已安装：curl -fsSL https://jimeng.jianying.com/cli | bash  且 dreamina login
# 默认若存在 ../.cursor/skills/dreamina-cli-skill/scripts 则 H5 模型列表显示 dreamina-text2video / dreamina-image2video
# DREAMINA_ENABLED=0          # 设为 0 可关闭即梦选项（即使 skill 目录存在）
# DREAMINA_SCRIPTS_DIR=       # 指向 dreamina-cli-skill/scripts 绝对路径（部署到无 .cursor 目录的服务器时必填）
# DREAMINA_BIN=               # **Windows 常见**：未把 dreamina 加入系统 PATH 时必填；官方安装器默认 C:\Users\你\bin\dreamina.exe，Git Bash 常见 C:\Users\你\.local\bin\dreamina
# DREAMINA_PATH_PREFIX=       # 可选：额外 prepend 到 PATH（目录，非可执行文件）
# PYTHON_EXE=                 # 即梦 wrapper 用；未填时 Windows 会尝试扫 %LOCALAPPDATA%\Programs\Python\Python3*\python.exe，再回退 py -3
# DREAMINA_POLL_SEC=600       # text2video/image2video 轮询超时（秒），最长 3600
# DREAMINA_MAX_CONCURRENT=5  # 同时提交即梦任务数（默认 5）。高级会员可并发多个；若收到 ret=1310 ExceedConcurrencyLimit 错误，酌情调低
# DREAMINA_TEXT2VIDEO_MODEL=seedance2.0   # 或 seedance2.0fast
# DREAMINA_MULTIMODAL_MODEL=seedance2.0fast   # 全能参考 multimodal2video（默认 seedance2.0fast）

# 可灵 Kling 视频（与 Veo 二选一；配置后 GET /api/video/models 会追加可灵模型）
# Garena clipai：KLING_API_BASE_URL=https://clipai.ingarena.net（POST /api/kling/omni-video，GET /api/kling/video-list 轮询；Bearer + API Key）
# 快手官方北京域：https://api-beijing.klingai.com（文生 /v1/videos/text2video；Omni /v1/videos/omni-video）
# 代码会按域名自动选路径；ingarena 的 omni 仅支持 model_name 为 kling-video-o1 | kling-v3-omni（kling-v3 会映射为 kling-v3-omni）
# KLING_API_KEY=长期_API_Key
# KLING_API_BASE_URL=https://clipai.ingarena.net
# KLING_MODELS=kling-v3-omni,kling-v3,kling-video-o1
# KLING_DEFAULT_MODEL=kling-v3-omni
# KLING_MODE=standard
# KLING_CALLBACK_URL=
# KLING_MAX_REF_IMAGES=7
# KLING_POLL_MS=2000
# KLING_POLL_MAX=600
# 可灵 HTTP 默认直连，不使用系统 HTTPS_PROXY（clipai.ingarena 经公司代理常 403）。仅当必须让可灵也走代理时显式设置：
# KLING_HTTP_PROXY=http://127.0.0.1:7890
# 本地 403 与 H5 不一致时：在项目根执行 npx tsx scripts/diagnose-kling-ingarena.ts（GET video-list 探测）
# 已有 kling-ref-cache/{uuid}.mp4、不再下 TikTok 时：npx tsx scripts/test-kling-omni-ref-cache-only.ts（须 API_PUBLIC_BASE_URL 与公司部署一致）
# clipai ingarena 参考图：默认 image_url 为纯 base64；若平台要求 data URL，设 KLING_INGARENA_IMAGE_DATAURL=1
# Omni 参考视频（TikTok/抖音）：后端用 yt-dlp 下载到 output/kling-ref-cache；**仅支持 http(s) URL** 提交给可灵（勿用 base64）
# 须配置 API_PUBLIC_BASE_URL（或下述别名）+ 路径 /api/video/kling/ref-cache/:uuid，勿依赖 yt-dlp -g CDN 直链
# https://github.com/yt-dlp/yt-dlp/releases
# YT_DLP_PATH=C:\\Tools\\yt-dlp.exe
# YT_DLP_PROXY=http://127.0.0.1:7890
# YT_DLP_TIMEOUT_MS=120000
# YT_DLP_DOWNLOAD_TIMEOUT_MS=300000
# 与 H5 的 VITE_API_BASE_URL 指向同一部署（无尾斜杠），ingarena 将 GET 该根下的 /api/video/kling/ref-cache/:uuid
# API_PUBLIC_BASE_URL=https://api.example.com
# 本地用 ngrok 暴露 3001 调试可灵参考视频时：填 ngrok 面板里 public_url 的根（无尾斜杠），改隧道后须同步修改并重启后端
# API_PUBLIC_BASE_URL=https://xxxx.ngrok-free.app
# 别名，与上一项二选一；便于与前端命名对齐
# H5_PUBLIC_API_BASE_URL=https://api.example.com
# KLING_REF_VIDEO_PUBLIC_BASE=https://api.example.com
# 若 API_SELF_BASE_URL 已是公网/内网可达地址（非 localhost），也会作为兜底用于拼 ref-cache URL
# 缓存文件默认约 30 分钟后删除（毫秒）
# KLING_REF_CACHE_TTL_MS=1800000
# 仅调试：仍用 yt-dlp -g 直链提交（易 DatabaseError）
# KLING_ALLOW_SOCIAL_VIDEO_URL=1

# 剪辑工作台 · 智能选段（ffmpeg-static + 可选 Compass 多模态）
# —— 剪辑 Agent：长素材默认服务端自动音频缩窗（前端无开关）；显式关闭：——
# EDITOR_VISION_AUTO_FOCUS=0
# EDITOR_ANALYSIS_MODE=hybrid   # off | audio | vision | hybrid（默认 hybrid：音频能量 + 抽帧 Gemini）
# EDITOR_VISION_AUTO_FOCUS_MIN_DURATION_SEC=120
# EDITOR_VISION_AUTO_FOCUS_LOG=1            # 调试：自动缩窗区间
# EDITOR_ANALYSIS_MAX_SEC=900   # 单素材分析的最大时长（秒）
# EDITOR_VISION_MAX_FRAMES=56    # 均匀抽帧数量上限（默认 56，硬顶 96；与 MIN_INTERVAL 共同决定密度）
# EDITOR_VISION_MIN_INTERVAL_SEC=1.0  # 未设置 FRAMES_PER_MINUTE 时：目标间隔（秒），越小越密（下限 0.55）
# EDITOR_VISION_FRAMES_PER_MINUTE=     # 可选，例如 24=每分钟约 24 帧（与 MAX_FRAMES 取小）
# EDITOR_VISION_BATCH_SIZE=8     # 每批送 Gemini 的录屏帧数（默认 8；再降可 6，但请求次数变多）
# EDITOR_VISION_SCORE_THRESHOLD=4.5  # 视觉分数转区间时的下限
# EDITOR_GAME_TAXONOMY_PATH=config/game-taxonomy.json  # 可选；不设则自动使用存在的 config/game-taxonomy.json
# EDITOR_TAXONOMY_REF_PER_LABEL=3   # 每类参考图最多张数（见 config/taxonomy-refs/README.md）
# EDITOR_TAXONOMY_REF_MAX=24        # 参考图全局上限（避免首包多模态过大）
# EDITOR_BEAT_MIN_GAP_SEC=0.45  # onset 卡点最小间隔（秒）
# EDITOR_BEAT_ONSET_THRESHOLD_MUL=0.95  # onset 峰值分位阈值系数
# EDITOR_LLM_LOG_USAGE=1        # 每次 Compass chat/completions 在服务端打印 usage（JSON）；网关未透传时仍会打提示
# EDITOR_VISION_FOCUS_WINDOW_SEC=60  # 默认缩窗长度（秒）；亦可由 API visionFocus.windowSec 覆盖
# EDITOR_VISION_FOCUS_MAX_SEC=120    # manual/audio 模式下单窗长度上限（钳制用）
# EDITOR_UPLOAD_MAX_MB=2048   # 剪辑工作台本地上传单文件上限 MB（64–4096，默认 2048）；改后需重启 API，前端会拉 /api/editor/upload-config
# FFMPEG_PATH= / FFPROBE_PATH=   # 可选，覆盖内置静态二进制，生产常用系统 ffmpeg

# ========== 服务器（本地开发专用，不上传到服务器）==========
# SERVER_HOST=43.134.x.x
# SERVER_USER=ubuntu
# SERVER_AUTH=password
# SERVER_PASSWORD=         # ⚠️ 仅本地部署脚本使用，禁止上传到服务器 .env

# ========== 服务配置 ==========
# Server
PORT=3001
# 可选：生产环境数据根目录（上传、即梦缓存、默认 output/）。挂载云硬盘时设为挂载点，例如 /data/qas
# 与 VIDEO_OUTPUT_DIR 二选一逻辑：未设 VIDEO_OUTPUT_DIR 时，输出目录为 <API_DATA_DIR>/output
# API_DATA_DIR=/data/qas
# GeeLark 上传时若 videoUrl 为相对路径 /api/video/...，Node 会回环请求本服务拉流；Docker/多网卡时可显式指定
# API_SELF_BASE_URL=http://127.0.0.1:3001
