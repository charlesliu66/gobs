# GeeLark API 配置（示例，请复制为 .env 并填入真实值）
# 文档：en-doc.zip / https://open.geelark.com

GEELARK_API_KEY=your_api_key_here
GEELARK_APP_ID=your_app_id_here
GEELARK_BEARER_TOKEN=your_bearer_token_here
GEELARK_BASE_URL=https://openapi.geelark.com/open/v1

# 可选：TikTok 评论「AI 生成」时使用（不配置则用内置预设备选）
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4o-mini
