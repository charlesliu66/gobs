# Google OAuth Client ID（用于「连接 Google Drive」）
# 从 https://console.cloud.google.com 创建 OAuth 2.0 客户端 ID（Web 应用）
# 需配置「已授权的 JavaScript 来源」包含开发地址（如 http://localhost:5173）
VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# Drive 素材文件夹 ID（只检索此文件夹及子文件夹内的图片/视频，留空则检索整个 Drive）
# 从链接 https://drive.google.com/.../folders/{此处即文件夹ID} 获取
VITE_DRIVE_FOLDER_ID=

# 后端 API 根地址。留空则请求相对路径 /api（由 Vite 代理到 3001，手机局域网访问时请留空，勿写 localhost）
# 部署后请填公网/公司网可访问的 API 根；若需可灵拉取 TikTok 参考视频，h5-video-tool-api 的 API_PUBLIC_BASE_URL 应与这里一致
# VITE_API_BASE_URL=http://127.0.0.1:3001

# Mock 切换（壳子阶段，API 未就绪时设为 true）
VITE_USE_MOCK_PROMPT=true
VITE_USE_MOCK_VIDEO=true
