# OpenAI（也可仅在 Streamlit 侧边栏填写）
OPENAI_API_KEY=
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# TikTok-Api：建议从浏览器 Cookie 复制 msToken
TIKTOK_MS_TOKEN=

# SQLite 路径（可选，默认为本目录 tiktok_bot.db）
# TIKTOK_BOT_DB=

# GeeLark：启动时会自动读取「仓库根目录」.env，一般只需在 d:\AI\SJ\.env 配置 GEELARK_BEARER_TOKEN
# 云手机 id 列表（逗号分隔）
GEELARK_PHONE_IDS=id1,id2
# 或使用 JSON 文件：[{"id":"..."},{"id":"..."}]
# GEELARK_ACCOUNTS_JSON=C:/path/accounts.json

# true 时使用 rpa/task/tiktokRandomCommentAsia
GEELARK_USE_ASIA=false
