# ========== 复制本文件为 .env.local 后填写；或运行 npm run setup:env ==========
#
# 开发时用手机/同一局域网其他设备访问本机 IP（如 http://192.168.1.5:3000）时，
# 必须在下方填写本机局域网 IPv4，否则 Next 会拦截 /_next 资源导致白屏。
# 多个用英文逗号分隔；与 ipconfig 里「无线局域网适配器」的 IPv4 一致。
# ALLOWED_DEV_ORIGINS=192.168.1.5,10.21.28.142
#
# 登录会话签名（必填，至少 32 字符随机串）。生产环境务必设置，勿提交仓库。
# AUTH_SECRET=请替换为长随机字符串
#
# （可选）公网访问域名，用于设置页「代理统计」等处生成完整下载链接；不填则用浏览器当前 origin
# NEXT_PUBLIC_SITE_URL=https://你的项目.vercel.app
#
# GeeLark（必填）
GEELARK_BEARER_TOKEN=your_bearer_token
GEELARK_BASE_URL=https://openapi.geelark.com/open/v1
# （可选）Facebook 评论 RPA 路径；与控制台 OpenAPI 文档一致时一般无需修改。默认 rpa/task/facebookRandomComment
# GEELARK_FB_COMMENT_PATH=rpa/task/facebookRandomComment

# ========== SeaTalk 通知（Open API：优先单聊 owner）==========
# 开放平台 Basic Info 中的 App ID / App Secret；机器人已与你单聊过（或可加为好友）后填你的 employee_code。
SEATALK_APP_ID=
SEATALK_APP_SECRET=
# 你的 employee_code（与 SeaTalk 里一致，一般不是链接里的 seatalk_id）。配置了则优先发单聊，不再发群。
SEATALK_EMPLOYEE_CODE=

# 仅当未配置 SEATALK_EMPLOYEE_CODE 时才会发群；二选一即可
# SEATALK_GROUP_ID=

# 可选：纯文本消息（1=纯文本 format=2；不填则 Markdown format=1）
# SEATALK_MESSAGE_PLAIN=1

# 若优先使用自定义 Webhook（配置了则优先走 Webhook，不再用上方 App 发消息）
# SEATALK_WEBHOOK_URL=
# SEATALK_WEBHOOK_TOKEN=

# 事件回调：开放平台 Event Callback 页里的 Signing Secret；回调 URL 填 https://你的域名/api/seatalk/callback
# SEATALK_SIGNING_SECRET=

# ========== 任务状态轮询 → SeaTalk（需 Cron + 持久化）==========
# 运行 npm run setup:env 会自动追加随机 CRON_SECRET；也可自行设置一串长随机字符
CRON_SECRET=

# Vercel KV 绑定项目后自动提供（推荐）
KV_REST_API_URL=
KV_REST_API_TOKEN=

# 或使用 Upstash Redis REST（与上二选一即可）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# 自定义状态文件路径（可选，默认 web/.data/seatalk-task-state.json）
# SEATALK_TASK_STATE_FILE=

# 可选：云手机无等待/进行中任务且待机时自动关机（与养号完成关机互补；默认关闭，勿在需长期开机手动操作的设备上开启）
# AUTO_SHUTDOWN_IDLE_PHONES=1

# 可选：夜间静默（与 GeeLark 云手机名称 serialName 一致，逗号分隔）。每日 21:00–次日 09:00（QUIET_HOURS_TIMEZONE）禁止开机与养号；若此时段内已开机，由 Cron 尽快关机（配合每分钟 warmup-dispatch 一般 1 分钟内）
# QUIET_HOURS_PHONE_NAMES=TEST3,ID
# QUIET_HOURS_TIMEZONE=Asia/Shanghai

# ========== 可选：AI 生成评论 / 规则库批量生成 ==========
# 密钥放在「本目录」web/.env.local（与 package.json 同层）。生成评论：若配置了 GEMINI_API_KEY 则优先 Gemini，否则用 OPENAI_API_KEY。
# GEMINI_API_KEY= 或 GOOGLE_API_KEY=
# OPENAI_API_KEY=sk-...
# GEMINI_MODEL=（可选）
# 改完后务必重启 npm run dev。自检：/api/ai-config-status
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4o-mini
# 全局 Safety Filter：将 commander.py 并入每次生成（规则库之外额外生效）
# 默认查找顺序：COMMENT_COMMANDER_PY_PATH → 当前工作目录 commander.py → 上级目录 commander.py → web/commander.py
# COMMENT_COMMANDER_PY_PATH=D:\\path\\to\\commander.py
