# 复制本文件为 .env 并填入真实 Key（.env 勿提交 Git）
# Copy to .env and fill in your keys. Do not commit .env.

# ========== Compass（与 QAS h5-video-tool-api 共用，推荐） ==========
# 首帧/尾帧生图 + 视频生成 均使用 Compass，无需火山 Ark
# COMPASS_API_KEY=你的Compass_Key
# COMPASS_API_URL=https://compass.llm.shopee.io/compass-api/v1
# COMPASS_VIDEO_MODEL=veo-2.0-generate-001
# COMPASS_IMAGEN_MODEL=imagen-4.0-generate-preview-06-06
# FRAME_IMAGE_PROVIDER=compass   # 留空或 compass 时用 Compass Imagen

# ========== 首帧/尾帧生图（Compass 未配置时可选） ==========
# Google / Gemini（AIzaSy 开头的 Key）
# GEMINI_API_KEY=

# 火山 Ark Seedream 文生图（需 FRAME_IMAGE_PROVIDER=volcano）
# FRAME_IMAGE_API_KEY=你的Ark的UUID
# FRAME_IMAGE_API_URL=volcano
# FRAME_IMAGE_API_MODEL=ep-xxxxxxxx-xxxx

# ========== 视频生成（Compass 未配置时可选） ==========
# 火山 Ark Seedance：call_kling_api.py
# SEEDANCE_API_KEY=你的Ark的UUID
