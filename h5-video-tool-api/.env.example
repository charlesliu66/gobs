# LLM（一键 Prompt 使用 Gemini）
GEMINI_API_KEY=你的Gemini密钥
# 获取：https://aistudio.google.com/app/apikey

# 代理（可选，解决「User location is not supported」地区限制）
# GEMINI_PROXY=http://127.0.0.1:7890
# 或使用系统代理：HTTPS_PROXY=http://127.0.0.1:7890

# Seedance (laozhang.ai 等)
SEEDANCE_API_URL=https://api.laozhang.ai/v2/generate/text
SEEDANCE_API_KEY=xxx

# Google OAuth (后端代理 Drive 时用)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# GeeLark (Phase 2)
GEELARK_API_KEY=xxx

# GeeLark TikTok 矩阵（批量评论、云手机、任务日志）- 与 SJ 项目一致，默认国际区 geelark.com
# 认证二选一：Bearer Token 或 Key 验证。若 Bearer 报 signature verification failure，可改用 Key 验证
# 方式 1：Bearer Token 认证（推荐，与 SJ 相同）
GEELARK_BEARER_TOKEN=你的Bearer_Token
# 方式 2：Key 验证（需同时配置 appId 和 apiKey）
# GEELARK_APP_ID=你的应用ID
# GEELARK_API_KEY=你的API_Key
# 国内区（geelark.cn）需显式指定：
# GEELARK_SJ_BASE_URL=https://openapi.geelark.cn/open/v1
# 一键发布报 connect ETIMEDOUT 时：与 Clash 同端口，例 http://127.0.0.1:7890；或与公司 HTTP 代理一致
# GEELARK_HTTP_PROXY=http://127.0.0.1:7890
# 视频上传到 OSS 时若遇 403，可设置代理（内网/防火墙环境）
# GEELARK_UPLOAD_PROXY=http://127.0.0.1:7890

# Compass 视频生成 (https://compass.llm.shopee.io/docs/CAPABILITIES/video-generation)
COMPASS_API_URL=https://compass.llm.shopee.io/compass-api/v1
COMPASS_API_KEY=你的Compass_API_Key
# VEO3 模型（模型 id 含 veo-3）专用第二把 Key；未配置时回退使用 COMPASS_API_KEY
# COMPASS_API_KEY2=你的Compass_VEO3_Key
# 仅在组织已开通对应模型时，用 VEO_MODELS 把 VEO3 加进 H5 下拉，例如：
# VEO_MODELS=veo-2.0-generate-001,veo-3.1-generate-001
# 图像生成（Boss 展示首尾帧等）：若 imagen-4.0 报 404，可设 COMPASS_IMAGEN_MODEL=imagen-3.0-generate-002
# COMPASS_IMAGEN_MODEL=imagen-3.0-generate-002
# 模型：veo-2 | veo-3（Google VEO）或 sora-2（OpenAI Sora），默认 veo-2
COMPASS_VIDEO_MODEL=veo-2
# 前端可选模型（逗号分隔），默认仅 veo-2.0；若组织已开通 veo-3 可添加：veo-3.1-generate-001 等
# VEO_MODELS=veo-2.0-generate-001,veo-2.0-generate-exp

# 可灵 Kling 视频（与 Veo 二选一；配置后 GET /api/video/models 会追加可灵模型）
# Garena clipai：KLING_API_BASE_URL=https://clipai.ingarena.net（POST /api/kling/omni-video，GET /api/kling/video-list 轮询；Bearer + API Key）
# 快手官方北京域：https://api-beijing.klingai.com（文生 /v1/videos/text2video；Omni /v1/videos/omni-video）
# 代码会按域名自动选路径；ingarena 的 omni 仅支持 model_name 为 kling-video-o1 | kling-v3-omni（kling-v3 会映射为 kling-v3-omni）
# KLING_API_KEY=长期_API_Key
# KLING_API_BASE_URL=https://clipai.ingarena.net
# KLING_MODELS=kling-v3-omni,kling-v3,kling-video-o1
# KLING_DEFAULT_MODEL=kling-v3-omni
# KLING_MODE=standard
# KLING_CALLBACK_URL=
# KLING_MAX_REF_IMAGES=7
# KLING_POLL_MS=2000
# KLING_POLL_MAX=600
# 可灵 HTTP 默认直连，不使用系统 HTTPS_PROXY（clipai.ingarena 经公司代理常 403）。仅当必须让可灵也走代理时显式设置：
# KLING_HTTP_PROXY=http://127.0.0.1:7890
# 本地 403 与 H5 不一致时：在项目根执行 npx tsx scripts/diagnose-kling-ingarena.ts（GET video-list 探测）
# 已有 kling-ref-cache/{uuid}.mp4、不再下 TikTok 时：npx tsx scripts/test-kling-omni-ref-cache-only.ts（须 API_PUBLIC_BASE_URL 与公司部署一致）
# clipai ingarena 参考图：默认 image_url 为纯 base64；若平台要求 data URL，设 KLING_INGARENA_IMAGE_DATAURL=1
# Omni 参考视频（TikTok/抖音）：后端用 yt-dlp 下载到 output/kling-ref-cache
# clipai.ingarena：曾尝试将参考视频以纯 base64 写入 video_list（实验性；多数环境会 DatabaseError，因与参考图校验不同）。生产请用 API_PUBLIC_BASE_URL + /api/video/kling/ref-cache/ 或 OSS 公网 URL
# KLING_SOCIAL_REF_VIDEO_USE_BASE64=1
# 否则再拼公网 URL 给可灵拉取（勿依赖 -g CDN 直链）
# https://github.com/yt-dlp/yt-dlp/releases
# YT_DLP_PATH=C:\\Tools\\yt-dlp.exe
# YT_DLP_PROXY=http://127.0.0.1:7890
# YT_DLP_TIMEOUT_MS=120000
# YT_DLP_DOWNLOAD_TIMEOUT_MS=300000
# 与 H5 的 VITE_API_BASE_URL 指向同一部署（无尾斜杠），ingarena 将 GET 该根下的 /api/video/kling/ref-cache/:uuid
# API_PUBLIC_BASE_URL=https://api.example.com
# 别名，与上一项二选一；便于与前端命名对齐
# H5_PUBLIC_API_BASE_URL=https://api.example.com
# KLING_REF_VIDEO_PUBLIC_BASE=https://api.example.com
# 若 API_SELF_BASE_URL 已是公网/内网可达地址（非 localhost），也会作为兜底用于拼 ref-cache URL
# 缓存文件默认约 30 分钟后删除（毫秒）
# KLING_REF_CACHE_TTL_MS=1800000
# 仅调试：仍用 yt-dlp -g 直链提交（易 DatabaseError）
# KLING_ALLOW_SOCIAL_VIDEO_URL=1

# Server
PORT=3001
# GeeLark 上传时若 videoUrl 为相对路径 /api/video/...，Node 会回环请求本服务拉流；Docker/多网卡时可显式指定
# API_SELF_BASE_URL=http://127.0.0.1:3001
